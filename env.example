# Facebook Messenger Bot - Variables de Entorno
# Desarrollado por Panacea Icono S.A.
# 
# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Completa los valores con tus tokens reales
# 3. NUNCA subas el archivo .env al repositorio

# ===========================================
# CONFIGURACIÓN DE FACEBOOK MESSENGER
# ===========================================

# Token de verificación del webhook (debe coincidir con el configurado en Facebook)
FB_VERIFY_TOKEN=pon-un-token-unico-para-verificar

# Page Access Token de tu página de Facebook
FB_PAGE_TOKEN=EAAG...tu_page_access_token_aqui

# Versión de la API de Facebook (recomendado: v20.0)
FB_API_VERSION=v20.0

# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================

# Puerto del servidor (por defecto: 8080)
PORT=8080

# Entorno de ejecución (development/production)
FLASK_ENV=production

# ===========================================
# CONFIGURACIÓN DE LOGGING
# ===========================================

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===========================================
# CONFIGURACIÓN DE SEGURIDAD
# ===========================================

# Clave secreta para Flask (genera una nueva para producción)
SECRET_KEY=tu_clave_secreta_muy_segura_aqui

# ===========================================
# CONFIGURACIÓN DE MONITOREO
# ===========================================

# URL del webhook para notificaciones (opcional)
WEBHOOK_URL=https://tu-dominio.com/webhook

# ===========================================
# CONFIGURACIÓN DE PANACEA ICONO
# ===========================================

# Información de la empresa
COMPANY_NAME=Panacea Icono S.A.
COMPANY_EMAIL=info@panacea-icono.com
COMPANY_WEBSITE=https://panacea-icono.com
COMPANY_GITHUB=@panacea-icono

# ===========================================
# CONFIGURACIÓN DE DESARROLLO
# ===========================================

# Para desarrollo local (opcional)
DEBUG=False
RELOAD=True

# ===========================================
# CONFIGURACIÓN DE DOCKER
# ===========================================

# Configuración específica para Docker
DOCKER_ENV=True
CONTAINER_NAME=panacea-facebook-bot
