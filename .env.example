# =============================
# Environment Variables Template
# =============================
# Copia este archivo a .env y completa con tus tokens reales
# NUNCA subas .env al repositorio

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Facebook Messenger Configuration
FB_PAGE_TOKEN=your_facebook_page_access_token_here
FB_APP_SECRET=your_facebook_app_secret_here
FB_VERIFY_TOKEN=your_custom_verify_token_here

# Rasa Pro Token (opcional)
RASA_PRO_TOKEN=your_rasa_pro_token_here

# Database Configuration (opcional)
DATABASE_URL=sqlite:///./bot.db

# Additional Configuration
DEBUG=true
LOG_LEVEL=DEBUG