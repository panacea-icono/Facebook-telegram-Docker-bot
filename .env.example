# Rasa Configuration
RASA_PORT=5005
ACTION_SERVER_PORT=5055
REDIS_PORT=6379
RASA_X_PASSWORD=admin

# Telegram Bot Configuration
TELEGRAM_ACCESS_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_VERIFY=your_telegram_webhook_verify_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhooks/telegram/webhook

# Facebook Messenger Configuration
FACEBOOK_VERIFY=your_facebook_verify_token
FACEBOOK_SECRET=your_facebook_app_secret
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# Security Settings
# Generate a random string for webhook verification
# You can use: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret_key_here

# Domain Configuration (Update with your actual domain)
DOMAIN=your-domain.com
PROTOCOL=https